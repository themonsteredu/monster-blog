{
  "manifest_version": 3,
  "name": "더몬스터학원 블로그 자동화",
  "version": "1.1.4",
  "description": "사진/주제로 네이버 블로그 글을 만들고, 네이버 글쓰기 화면에 자동으로 입력합니다.",
  "permissions": [
    "storage",
    "scripting",
    "activeTab",
    "clipboardWrite"
  ],
  "host_permissions": [
    "https://api.anthropic.com/*",
    "https://blog.naver.com/*",
    "https://*.naver.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "더몬스터학원 블로그 자동화"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.naver.com/*"
      ],
      "js": [
        "content.js"
      ],
      "all_frames": true,
      "match_about_blank": true,
      "match_origin_as_fallback": true,
      "run_at": "document_idle"
    }
  ]
}